# WysPS reverse proxy baseline config
# Copy this file to .env and fill values for your environment.

# Core ports
GTPS_UDP_PORT=17091
WG_PORT=51820

# WireGuard addressing
WG_SUBNET=10.0.0.0/24
WG_GATE_IP=10.0.0.1/24
WG_MAIN_IP=10.0.0.2/24
WG_HANDSHAKE_TIMEOUT_SEC=90

# SSH hardening (gate server)
SSH_NEW_PORT=8922
ADMIN_USER=wyspsadmin
# ADMIN_PUBLIC_KEY="ssh-ed25519 AAAA..."
# ADMIN_AUTHORIZED_KEYS_FILE="/root/.ssh/authorized_keys"

# Metadata / references
MAIN_PUBLIC_IP=203.0.113.10
MAIN_SSH_USER=root
MAIN_SSH_PORT=22
GATE_PUBLIC_IP=198.51.100.5

# WireGuard peer keys
# Fill these after generating keys on each node.
MAIN_WG_PUBLIC_KEY=
WG_GATE_PUBLIC_KEY=

# L7 mitigation
RATE_LIMIT_PPS=50
RATE_LIMIT_BURST=100

# Optional overrides
# PUBLIC_INTERFACE=eth0
# FIREWALL_READY=true